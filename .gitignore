# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/

# Local environment and secrets
.env
.env.*
!.env.example

# Editor/OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs and local artifacts
*.log
_internal/*.local.md

# Benchmark artifacts
experiments/*/data/raw/*
!experiments/*/data/raw/.gitkeep

# Benchmark results
# Default: keep result CSVs local, except explicit shared outputs.
experiments/*/results/*
!experiments/*/results/.gitkeep
!experiments/*/results/run_manifest.csv
!experiments/*/results/shared/
!experiments/*/results/shared/.gitkeep
!experiments/*/results/shared/*.csv
!experiments/*/results/shared/reviews/
!experiments/*/results/shared/reviews/*.md
